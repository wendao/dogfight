page {
  --paper: #f6f2e7;
  --card: #fffdf6;
  --line: #e3dcc6;
  --grid: #c6d4e6;
  --ink: #22395c;
  --ink-soft: #5c6f8c;
  --sky: #5fa9dd;
  --hit: #3d9463;
  --head: #d23b34;
  --pen: #c0392b;
  --muted: #8d8672;
  background: var(--paper);
  color: var(--ink);
  font-size: 28rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: var(--card);
  border: 1px solid #e0d8bf;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 0 rgba(34, 57, 92, 0.07);
  padding: 28rpx 32rpx;
  margin: 0 24rpx;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1.5px solid var(--ink);
  border-radius: 12rpx;
  background: var(--ink);
  color: #fdfaf2;
  font-size: 28rpx;
  padding: 16rpx 36rpx;
  letter-spacing: 2rpx;
}

.btn.ghost {
  background: transparent;
  color: var(--ink);
}

.btn.red {
  background: var(--pen);
  border-color: var(--pen);
}

.btn.sm {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
}

.btn[disabled] {
  opacity: 0.45;
}

.note {
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.7;
}

.red-ink {
  color: var(--pen);
}

.sec {
  font-size: 34rpx;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.hud {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.big {
  font-size: 40rpx;
  color: var(--pen);
  font-weight: 600;
}

.center {
  text-align: center;
}
