<view class="page">
  <view class="sub">对手：{{oppName}}</view>

  <view class="board-wrap">
    <view class="who">我的阵地</view>
    <board cells="{{cells}}" locked="{{submitted}}" selIdx="{{selIdx}}" bind:celltap="onCell" />
  </view>

  <view class="card panel">
    <view class="sec">部署 3 架飞机</view>
    <view class="hud left">
      <text>剩余 <text class="big {{urgent ? 'urgent' : ''}}">{{timer}}</text> 秒</text>
      <text>已部署 <text class="big">{{count}}</text>/3</text>
    </view>
    <view class="note">朝向：{{oriName}}</view>
    <view class="mini">
      <view class="mi {{item}}" wx:for="{{mini}}" wx:key="index"></view>
    </view>
    <view class="btns">
      <button class="btn sm" bindtap="rotate">旋转</button>
      <button class="btn ghost sm" bindtap="undo">撤销</button>
      <button class="btn ghost sm" bindtap="clear">清空</button>
      <button class="btn ghost sm" bindtap="rand">随机</button>
    </view>
    <button class="btn red confirm" bindtap="confirm" disabled="{{!canConfirm}}">确认出击</button>
    <view class="note">{{status}}</view>
  </view>
</view>
